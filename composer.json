{
    "name": "piedweb/wp-ai-polyglot",
    "description": "Master/Shadow i18n architecture for WordPress + WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://wap.piedweb.com",
    "authors": [
        {
            "name": "Robin",
            "homepage": "https://en.piedweb.com"
        }
    ],
    "support": {
        "issues": "https://github.com/PiedWeb/wp-ai-polyglot/issues",
        "source": "https://github.com/PiedWeb/wp-ai-polyglot"
    },
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/woocommerce-stubs": "^9.0",
        "php-stubs/wp-cli-stubs": "^2.10"
    },
    "scripts": {
        "test": "phpunit",
        "test:filter": "phpunit --filter",
        "test:wc": "phpunit -c phpunit-wc.xml",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "phpstan:baseline": "phpstan analyse --generate-baseline=phpstan-baseline.neon"
    },
    "config": {
        "allow-plugins": {}
    }
}
